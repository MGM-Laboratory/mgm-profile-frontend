# =============================================================================
# MGM Profile Frontend — environment contract (PLACEHOLDERS ONLY — never commit
# real values). Copy to `.env.local` for development.
# =============================================================================

# ---- Auth.js v5 (Keycloak OIDC) ----
# AUTH_SECRET: generate with `npx auth secret` (or `openssl rand -base64 32`).
AUTH_SECRET=__generate_a_long_random_string__
# Public origin of this app (used for OAuth callbacks).
AUTH_URL=http://localhost:3000
# Keycloak web client. For a public PKCE client leave the secret empty.
AUTH_KEYCLOAK_ID=mgm-profile-web-staging
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=http://localhost:8081/realms/mgm

# ---- Backend API ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Search (public directory) — Phase 6.
# Prefer proxying Meilisearch through the backend; if querying directly from the
# browser, use a search-only key (never the master key).
# NEXT_PUBLIC_MEILI_HOST=http://localhost:7700
# NEXT_PUBLIC_MEILI_SEARCH_KEY=__search_only_key__
